PHORA_APP_NAME=phora-api
PHORA_ENVIRONMENT=local
PHORA_API_PREFIX=/api/v1
PHORA_DATABASE_URL=sqlite:///./phora.db
# For RDS PostgreSQL:
# PHORA_DATABASE_URL=postgresql+psycopg://phora_admin:<password>@<rds-endpoint>:5432/phora
PHORA_REDIS_URL=redis://localhost:6379/0
PHORA_BROKER_URL=redis://localhost:6379/1
PHORA_RESULT_BACKEND=redis://localhost:6379/2
PHORA_SECRET_KEY=change-me
PHORA_ACCESS_TOKEN_EXP_MINUTES=86400
PHORA_REFRESH_TOKEN_EXP_MINUTES=86400
PHORA_ALGORITHM=HS256
PHORA_API_PREFIX_LEGACY=/api/0.1.0
PHORA_ML_BASE_URL=http://ml-api.bloomy-ml.internal:8001
PHORA_ML_TIMEOUT_MS=5000
PHORA_ML_RETRY_COUNT=2
PHORA_ML_SHADOW_MODE=true
PHORA_AUTO_CREATE_TABLES=true
PHORA_HEALTH_SCHEMA=health
PHORA_BILLING_SCHEMA=billing
PHORA_AUDIT_SCHEMA=audit
PHORA_OTP_EXPIRATION_MINUTES=10
PHORA_OTP_LENGTH=6
PHORA_SMTP_ENABLED=false
PHORA_SMTP_HOST=smtp.example.com
PHORA_SMTP_PORT=587
PHORA_SMTP_USERNAME=username
PHORA_SMTP_PASSWORD=password
PHORA_SMTP_FROM_EMAIL=no-reply@phora.app
PHORA_SMTP_FROM_NAME=Phora
PHORA_SMTP_USE_TLS=true
PHORA_SMTP_USE_SSL=false
PHORA_FIREBASE_PROJECT_ID=
PHORA_FIREBASE_CREDENTIALS_JSON=
PHORA_FIREBASE_WEB_CLIENT_ID=
PHORA_FIREBASE_IOS_CLIENT_ID=
PHORA_FIREBASE_ANDROID_CLIENT_ID=
PHORA_GOOGLE_OAUTH_CLIENT_ID=
PHORA_GOOGLE_HEALTH_CLIENT_ID=
PHORA_GOOGLE_HEALTH_CLIENT_SECRET=
PHORA_GOOGLE_HEALTH_REDIRECT_URI=
PHORA_GOOGLE_HEALTH_OAUTH_SUCCESS_REDIRECT=vyla://wearables/google-health?status=connected
PHORA_GOOGLE_HEALTH_OAUTH_ERROR_REDIRECT=vyla://wearables/google-health?status=error
PHORA_APPLE_BUNDLE_ID=com.vyla.health
PHORA_APPLE_SERVICE_ID=
PHORA_APPLE_IAP_SHARED_SECRET=
PHORA_PUBLIC_APP_URL=http://localhost:8000
PHORA_BLOG_MEDIA_BUCKET=
PHORA_BLOG_MEDIA_PUBLIC_BASE_URL=
PHORA_ANDROID_RELEASE_BUCKET=
PHORA_ANDROID_RELEASE_MANIFEST_KEY=android/latest.json
PHORA_ANDROID_RELEASE_PRESIGN_EXPIRATION_SECONDS=3600
# Optional direct fallback if Android APK is hosted outside the release manifest flow.
PHORA_ANDROID_DOWNLOAD_URL=
PHORA_STRIPE_SECRET_KEY=
PHORA_STRIPE_PUBLISHABLE_KEY=
PHORA_STRIPE_WEBHOOK_SECRET=
# Live Stripe price overrides. Required when PHORA_STRIPE_SECRET_KEY/PHORA_STRIPE_PUBLISHABLE_KEY use live keys.
# Set one monthly and one yearly live-mode Stripe Price ID for every supported country profile.
PHORA_STRIPE_PRICE_GB_MONTH=
PHORA_STRIPE_PRICE_GB_YEAR=
